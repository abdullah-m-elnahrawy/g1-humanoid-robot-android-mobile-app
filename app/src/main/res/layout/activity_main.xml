<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:fillViewport="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Audio Stream -->
        <TextView
            android:text="Audio Stream"
            android:textStyle="bold"
            android:textSize="22sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <EditText
                android:id="@+id/txtGroupIp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="239.255.0.1"
                android:inputType="text"
                android:maxLines="1" />

            <Space
                android:layout_width="12dp"
                android:layout_height="match_parent" />

            <EditText
                android:id="@+id/txtPort"
                android:layout_width="96dp"
                android:layout_height="wrap_content"
                android:hint="5555"
                android:inputType="number"
                android:maxLines="1" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/chkUnicast"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Send Unicast (instead of Multicast)"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnPTT"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="HOLD TO TALK" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33000000"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp" />

        <!-- Robot Control (UDP over multicast, uses robot_id only) -->
        <TextView
            android:text="Robot Control (UDP)"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/txtRobotId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Robot ID (e.g., hasan)"
            android:inputType="text"
            android:maxLines="1"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btnSaveRobot"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Robot ID"
            android:layout_marginTop="12dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33000000"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="10dp" />

        <TextView
            android:text="Motions"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnShake"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Shake Hands" />

            <Space
                android:layout_width="12dp"
                android:layout_height="match_parent" />

            <Button
                android:id="@+id/btnSalute"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Military Salute" />
        </LinearLayout>

        <Button
            android:id="@+id/btnWelcome"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Welcome Visitors" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="24dp" />
    </LinearLayout>
</ScrollView>

