<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:fillViewport="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Audio streaming section (unchanged behavior) -->
        <TextView
            android:text="@string/section_audio"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/txtGroupIp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/hint_group_ip"
                android:inputType="textUri" />

            <EditText
                android:id="@+id/txtPort"
                android:layout_marginStart="8dp"
                android:layout_width="96dp"
                android:layout_height="wrap_content"
                android:hint="@string/hint_port"
                android:inputType="number" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/chkUnicast"
            android:text="@string/label_unicast"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnPTT"
            android:text="@string/ptt_hold"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="56dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#303030" />

        <!-- NEW: Robot control target -->
        <TextView
            android:layout_marginTop="12dp"
            android:text="@string/section_robot_control"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/txtRobotIp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/hint_robot_ip"
                android:inputType="textUri" />

            <EditText
                android:id="@+id/txtRobotPort"
                android:layout_marginStart="8dp"
                android:layout_width="96dp"
                android:layout_height="wrap_content"
                android:hint="@string/hint_port"
                android:text="5577"
                android:inputType="number" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSaveRobot"
            android:text="@string/btn_save_robot"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#303030" />

        <!-- NEW: Motion buttons -->
        <TextView
            android:layout_marginTop="12dp"
            android:text="@string/section_motions"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnShake"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:text="@string/motion_shake" />

            <Button
                android:id="@+id/btnSalute"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:text="@string/motion_salute" />
        </LinearLayout>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnWelcome"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:text="@string/motion_welcome" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
